{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Blevins Holdings Newsroom",
  "theme": "willow",
  "colors": {
    "primary": "#f76040",
    "light": "#13c5be",
    "dark": "#a35cfb"
  },
  "favicon": "https://media.brand.dev/c219dc98-9ece-432d-a19a-173b64c97c8f.jpg",
  "logo": {
    "light": "https://media.brand.dev/b68fb600-5011-44b4-b123-7187e25f17e1.jpg",
    "dark": "https://media.brand.dev/b68fb600-5011-44b4-b123-7187e25f17e1.jpg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/bblevins721/blevins-holdings-newsroom"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bblevins721/blevins-holdings-newsroom"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "configuration"]
          },
          {
            "group": "Core Features",
            "pages": ["features/stories", "features/categories", "features/media", "features/search"]
          },
          {
            "group": "Customization",
            "pages": ["customization/layout", "customization/modules", "customization/internationalization"]
          },
          {
            "group": "Deployment",
            "pages": ["deployment/vercel", "deployment/docker", "deployment/environment-variables"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Hooks & Utilities",
            "pages": ["api/hooks", "api/modules", "api/components"]
          },
          {
            "group": "Routes",
            "pages": ["api/routes", "api/data-fetching"]
          }
        ]
      }
    ]
  }
}
